# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# Database (postgresql+asyncpg://user:pass@host:5432/dbname)
DATABASE_URL=postgresql+asyncpg://osb:osb@postgres:5432/osb_vk

# VK app credentials
VK_GROUP_ID=123456789
VK_GROUP_TOKEN=vk1.a.your_group_access_token
VK_CONFIRMATION_TOKEN=your_confirmation_token
VK_LONGPOLL_WAIT=25

# Roles
ADMIN_ID=123456789

# Log peer (conversation/chat peer_id, e.g. 2000000001)
LOG_PEER_ID=2000000001

# Optional file storage and signing
MEDIA_BASE_URL=
SECRET_KEY=change_me
